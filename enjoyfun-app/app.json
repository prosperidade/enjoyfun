{
  "expo": {
    "name": "EnjoyFun",
    "slug": "enjoyfun",
    "scheme": "enjoyfun",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.enjoyfun.app",
      "supportsTablet": true,
      "infoPlist": {
        "NSFaceIDUsageDescription": "Usamos Face ID para autorizar acoes criticas como execucao de ferramentas da IA."
      }
    },
    "android": {
      "package": "com.enjoyfun.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-local-authentication",
      "expo-notifications",
      "expo-asset",
      "expo-audio"
    ],
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    }
  }
}
