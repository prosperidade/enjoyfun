# ==============================================================================
# EnjoyFun Platform - Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ==============================================================================

# --- Database (PostgreSQL) ---------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=enjoyfun
# Compatibilidade com docker-compose/infra legada:
DB_DATABASE=enjoyfun
DB_USER=postgres
DB_PASS=your_database_password_here

# Application-level DB role for RLS (Row Level Security) enforcement.
# Migration 051/055 materialize the role and grants used by the application.
# Fail-closed: authenticated requests now require explicit app_user credentials.
DB_USER_APP=app_user
DB_PASS_APP=your_app_user_password_here

# --- JWT (RS256 Asymmetric) --------------------------------------------------
# The platform uses RS256 with PEM key files (private.pem / public.pem).
# Place the PEM files in the project root or set inline via these env vars.
# To generate a new key pair:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
#
# JWT_PRIVATE_KEY=<PEM contents with \n for line breaks>
# JWT_PUBLIC_KEY=<PEM contents with \n for line breaks>

# Token lifetimes (seconds)
JWT_EXPIRY=3600
JWT_REFRESH=2592000

# --- Legacy / OTP / Crypto Secrets ------------------------------------------
# Used by OTP hashing, SecretCryptoService, and PaymentGatewayService.
# Generate with: openssl rand -hex 32
# Or run: ./scripts/rotate_credentials.sh to generate all at once.
JWT_SECRET=generate_a_64_char_hex_secret_here

# Dedicated crypto keys (recommended for production — fall back to JWT_SECRET
# if not set, but rotating JWT_SECRET then affects ALL subsystems):
OTP_PEPPER=generate_a_64_char_hex_secret_here
MESSAGING_CREDENTIALS_KEY=generate_a_64_char_hex_secret_here
SENSITIVE_DATA_KEY=generate_a_64_char_hex_secret_here
FINANCE_CREDENTIALS_KEY=generate_a_64_char_hex_secret_here

# --- AI Providers (optional) -------------------------------------------------
# Keys are NEVER hardcoded. Services fail gracefully if not set.
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# --- Application -------------------------------------------------------------
APP_ENV=development
APP_DEBUG=false
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3003

# --- Auth Cookie (HttpOnly, on by default) -----------------------------------
# Access token is transported via HttpOnly cookie scoped to /api.
# Set to 0 to fall back to body-only transport (for Postman / legacy clients).
# AUTH_ACCESS_COOKIE_MODE=1
# AUTH_ACCESS_COOKIE_NAME=enjoyfun_access_token

# --- Features ----------------------------------------------------------------
FEATURE_WORKFORCE_BULK_CARD_ISSUANCE=true

# AI Feature Flags
FEATURE_AI_INSIGHTS=true
FEATURE_AI_TOOLS=true
FEATURE_AI_TOOL_WRITE=false
AI_BOUNDED_LOOP_V2=false
FEATURE_AI_WRITE_TIMELINE_CHECKPOINT=false
