          }
        },
        {
          "name": "Finance - Testar conexão (gateway por id)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test('Resposta de sucesso', function () { pm.expect(json.success).to.eql(true); });",
                  "pm.test('Possui data no payload', function () { pm.expect(json.data).to.exist; });"
                ]
